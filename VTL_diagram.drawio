        <mxCell id="428" value="VTL_sub.h &amp;mdash; агрегатор модуля (data + burn/convert/parse/style + infra)" style="shape=note;size=15;whiteSpace=wrap;html=1;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1715" y="4146" width="440" height="45" as="geometry" />
        </mxCell>
        <mxCell id="429" value="&lt;b&gt;Зачем этот модуль?&lt;/b&gt;&lt;br&gt;Работа с субтитрами. Поддерживает 4 формата: ASS, SRT, VTT, TTML (+ SBV для YouTube).&lt;br&gt;Субтитры можно настраивать (burn, convert, parse, style): цвет, фон, обводка, шрифт, размер, выравнивание.&lt;br&gt;&lt;b&gt;burn/convert/parse/style&lt;/b&gt; — операции, &lt;b&gt;infra/&lt;/b&gt; — чтение/запись/формат. Стили можно грузить из JSON через &lt;code&gt;StyleLoadFromJson()&lt;/code&gt;." style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=10;position=0.5;base=15;fillColor=#FFFFCC;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;" vertex="1" parent="1">
