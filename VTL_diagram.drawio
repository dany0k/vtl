        <mxCell id="571" value="&lt;b&gt;Зачем этот слой?&lt;/b&gt;&lt;br&gt;Это &lt;i&gt;фундамент&lt;/i&gt; всего проекта — базовые &amp;laquo;кирпичики&amp;raquo;, из которых строятся все остальные модули.&lt;br&gt;&lt;br&gt;&lt;b&gt;VTL_string.h&lt;/b&gt; — тип для строк (массив на 1024 символа)&lt;br&gt;&lt;b&gt;VTL_buffer_data.h&lt;/b&gt; — буфер для сырых данных (аудио, видео)&lt;br&gt;&lt;b&gt;VTL_file.h&lt;/b&gt; — чтение/запись файлов с диска&lt;br&gt;&lt;b&gt;VTL_time.h&lt;/b&gt; — работа со временем (для отложенных публикаций)&lt;br&gt;&lt;b&gt;VTL_encryptor.h&lt;/b&gt; — шифрование данных пользователя&lt;br&gt;&lt;b&gt;db/&lt;/b&gt; — credentals + connection + executor (полный слой БД)&lt;br&gt;&lt;b&gt;curl/&lt;/b&gt; — HTTP-клиент для платформ (TG, Reddit и пр.)&lt;br&gt;&lt;b&gt;VTL_console_log&lt;/b&gt; — вывод ошибок в консоль&lt;br&gt;&lt;br&gt;&lt;i&gt;Этот слой ни от чего не зависит — остальные зависят от него.&lt;/i&gt;" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=10;position=0.5;base=15;fillColor=#FFFFCC;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;" vertex="1" parent="1">
          <mxGeometry x="1530" y="5168" width="450" height="170" as="geometry" />
        </mxCell>
